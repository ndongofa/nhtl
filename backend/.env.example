# =====================================
# SPRING PROFILE
# =====================================
# Use "prod" in production, "dev" for local development
SPRING_PROFILES_ACTIVE=prod

# =====================================
# SERVER
# =====================================
PORT=8080

# =====================================
# DATABASE (PostgreSQL / Railway)
# =====================================
PGHOST=your-db-host
PGPORT=5432
PGDATABASE=your-db-name
PGUSER=your-db-user
PGPASSWORD=your-db-password

# =====================================
# SUPABASE
# =====================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# =====================================
# EMAIL — Brevo transactional API (recommended)
# =====================================
BREVO_API_KEY=your-brevo-api-key
# Sender address and display name
MAIL_FROM=no-reply@your-domain.com
MAIL_FROMNAME=SAMA Services International

# =====================================
# EMAIL — SMTP fallback (optional)
# Leave blank if using Brevo API above
# =====================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# =====================================
# SMS — Brevo transactional SMS
# =====================================
# Sender name shown on SMS (max 11 alphanumeric chars)
BREVO_SMS_FROM=SamaService

# =====================================
# WHATSAPP + SMS — Twilio
# Required only if using Twilio for WhatsApp notifications (prod profile)
# Sign up at https://www.twilio.com and get credentials from the Console
# =====================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Twilio SMS from-number (E.164, e.g. +33700000000)
TWILIO_FROM_NUMBER=+33700000000
# Twilio WhatsApp sender — use the sandbox number during development
# Production: replace with your approved WhatsApp Business number (whatsapp:+XXXXXXXXXXX)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886